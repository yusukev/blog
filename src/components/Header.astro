---
import { SITE_TITLE } from '../consts'
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
  </nav>
</header>
<style>
  header {
    width: 720px;
    max-width: calc(100% - 2em);
    height: var(--header-height);
    margin: auto;
  }
  nav {
    height: 100%;
    display: flex;
    align-items: center;
  }
  h2 {
    margin: 0;
    font-size: 1.2em;
  }
  nav h2 a {
    text-decoration: none;
    color: var(--black);
  }
</style>
