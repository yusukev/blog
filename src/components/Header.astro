---
import { SITE_TITLE } from '../consts'
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
  </nav>
</header>
<style>
  header {
    height: 60px;
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  nav {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  h2 {
    margin: 0;
    font-size: 1.2em;
  }
  nav h2 a {
    text-decoration: none;
    padding: 1em 0.5em;
    color: var(--black);
  }
</style>
